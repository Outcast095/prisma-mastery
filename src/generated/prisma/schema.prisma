// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. Описываем enum с возможными ролями
enum Role {
  USER
  ADMIN
  GUEST
}

enum Status {
  EMPLOYED
  UNEMPLOYED
}

model User {
  id              String  @id @default(uuid())
  email           String  @unique
  name            String?
  age             Int?
  isEmailVerified Boolean @default(false)
  city            String?
  isBlocked       Boolean @default(false)
  isPremium       Boolean @default(false)
  role            Role    @default(USER) // Роль пользователя (например, "USER", "ADMIN")
  status          Status  @default(UNEMPLOYED) // Статус пользователя (например, "EMPLOYED", "UNEMPLOYED")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts   Post[] // Один ко многим (User -> Post)
  profile Profile? // Один к одному (User -> Profile)

  @@map("users") // Переименование таблицы в базе данных на "users"
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String[]
  published Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String

  author User @relation(fields: [authorId], references: [id])

  // МНОГИЕ КО МНОГИМ: Связь с моделью Tag
  tags Tag[] // У одного поста может быть много тегов
}

model Profile {
  id  String @id @default(uuid())
  bio String

  ownerid Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

// Новая модель для тегов
model Tag {
  id   String @id @default(uuid())
  name String @unique // Уникальное имя тега (например, "postgres")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  // МНОГИЕ КО МНОГИМ: Обратная связь с моделью Post
  posts     Post[] // Один тег может быть у множества постов
}
